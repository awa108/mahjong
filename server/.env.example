# ──────────────────────────────────────────────
# 麻将服务端 — 环境变量模板
# ──────────────────────────────────────────────
# 复制此文件为 .env.local（不会被 git 追踪），填入真实值。
# cp server/.env.example server/.env.local
#
# 本地开发：仅需 PORT，登录走 mock（无需微信凭据）
# 生产环境：所有变量必须填写

# ── 微信小程序凭据 ───────────────────────────
# 小程序 AppID（公开，仅标识应用）
WX_APPID=wx1949e92d543a20ae

# 小程序 AppSecret（机密！从微信公众平台获取）
# 路径：微信公众平台 → 开发管理 → 开发设置 → AppSecret
WX_APPSECRET=your-app-secret-here

# ── CloudBase ────────────────────────────────
# CloudBase 环境 ID
TCB_ENV_ID=cloud1-d9ggcgqxc02c1aea9

# ── 服务端 ───────────────────────────────────
# 监听端口（默认 3000，CloudBase 云托管默认注入 PORT=8080）
PORT=3000

# ── JWT（未来迁移至 JWT 方案时使用）──────────
# 用于签发和校验 JWT token，替换当前的 crypto.randomBytes 方案。
# 生成方式：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# JWT_SECRET=your-jwt-secret-here
