# ──────────────────────────────────────────────
# 麻将小程序 — 环境变量模板
# ──────────────────────────────────────────────
# 复制此文件为 .env.local（不会被 git 追踪），填入真实值。
# cp .env.example .env.local
#
# 详细部署说明见 docs/DEPLOY.md

# ── 微信小程序 ──────────────────────────────
# 小程序 AppID（公开，可写入 project.config.json）
WX_APPID=wx1949e92d543a20ae

# 小程序 AppSecret（机密！仅服务端使用，严禁写入前端代码或提交 git）
WX_APPSECRET=your-app-secret-here

# ── CloudBase ────────────────────────────────
# CloudBase 环境 ID（公开，仅标识环境实例）
TCB_ENV_ID=cloud1-d9ggcgqxc02c1aea9

# ── 服务端 ───────────────────────────────────
# HTTP + WebSocket 监听端口（默认 3000）
PORT=3000

# ── JWT（未来迁移至 JWT 方案时使用）──────────
# JWT_SECRET=your-jwt-secret-here
