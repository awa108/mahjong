/* room 房间页 - 4 座网格，状态色区分 */

.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  box-sizing: border-box;
}

/* ── 横幅 ────────────────────────────── */

.banner {
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  font-size: 26rpx;
}

.banner.error {
  background: #ffebee;
  color: #c62828;
}

.banner.warn {
  background: #fff3e0;
  color: #e65100;
}

/* ── 顶栏 ────────────────────────────── */

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.room-code-box {
  display: flex;
  flex-direction: column;
}

.room-code-box .label {
  font-size: 24rpx;
  color: #999;
}

.room-code-box .code {
  font-size: 44rpx;
  font-weight: 700;
  color: #2d5016;
  letter-spacing: 6rpx;
}

.share-btn {
  background: #f0f0f0;
  color: #333;
  font-size: 26rpx;
  border-radius: 12rpx;
  border: none;
  padding: 0 24rpx;
  height: 64rpx;
  line-height: 64rpx;
}

/* ── 座位网格 ────────────────────────── */

.seat-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  flex: 1;
}

/* 座位卡片 */
.seat {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: 3rpx solid #e0e0e0;
  min-height: 220rpx;
  transition: border-color 0.2s, background 0.2s;
}

.seat.me {
  border-color: #2d5016;
  background: #f1f8e9;
}

.seat.ready {
  border-color: #4caf50;
  background: #e8f5e9;
}

.seat.empty {
  border-style: dashed;
  background: #fafafa;
}

/* 座位标签 */
.seat-label text {
  font-size: 40rpx;
  font-weight: 700;
  color: #999;
}

.seat.me .seat-label text {
  color: #2d5016;
}

/* 昵称 */
.seat-nickname {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 在线状态 */
.seat-status {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.seat-status text {
  font-size: 22rpx;
  color: #999;
}

.seat-status .dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.dot.online {
  background: #4caf50;
}

.dot.offline {
  background: #bdbdbd;
}

/* 准备标签 */
.ready-tag {
  background: #4caf50;
  border-radius: 8rpx;
  padding: 6rpx 20rpx;
}

.ready-tag text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 500;
}

.ready-tag.not-ready {
  background: #e0e0e0;
}

.ready-tag.not-ready text {
  color: #999;
}

/* 空位文字 */
.seat-empty-text {
  font-size: 28rpx;
  color: #bbb;
}

/* ── 底部操作 ────────────────────────── */

.bottom-bar {
  margin-top: 32rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.info-row {
  text-align: center;
  margin-bottom: 20rpx;
}

.info-row text {
  font-size: 28rpx;
  color: #666;
}

.action-row {
  display: flex;
  gap: 16rpx;
}

.btn-leave,
.btn-ready,
.btn-start {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.btn-leave {
  flex: 1;
  background: #eee;
  color: #666;
}

.btn-ready {
  flex: 2;
  background: #666;
  color: #fff;
}

.btn-start {
  flex: 2;
  background: #d32f2f;
  color: #fff;
}

.btn-start[disabled] {
  opacity: 0.5;
}

.btn-leave[disabled],
.btn-ready[disabled] {
  opacity: 0.5;
}
