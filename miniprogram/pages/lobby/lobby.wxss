/* lobby 大厅 — 卡片布局，创建/加入分区 */

.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: #f5f5f5;
}

/* ── 状态条 ──────────────────────────── */

.status-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff3e0;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.status-bar.connected {
  background: #e8f5e9;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #4caf50;
  margin-right: 12rpx;
}

.status-text {
  font-size: 26rpx;
  color: #e65100;
}

.status-bar.connected .status-text {
  color: #2e7d32;
}

.error-bar {
  background: #ffebee;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}

.error-bar text {
  font-size: 26rpx;
  color: #c62828;
}

/* ── 卡片 ────────────────────────────── */

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 36rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

/* ── 分区 ────────────────────────────── */

.section {
  display: flex;
  flex-direction: column;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2d5016;
  margin-bottom: 8rpx;
}

.section-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 32rpx;
}

/* ── 按钮 ────────────────────────────── */

.btn-primary {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #2d5016;
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
}

.btn-primary[disabled] {
  opacity: 0.6;
}

.btn-join {
  width: 140rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: #555;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  flex-shrink: 0;
}

.btn-join[disabled] {
  opacity: 0.6;
}

/* ── 加入行 ──────────────────────────── */

.join-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.code-input {
  flex: 1;
  height: 88rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 34rpx;
  letter-spacing: 8rpx;
  text-align: center;
  background: #fafafa;
  box-sizing: border-box;
}

.code-input:focus {
  border-color: #2d5016;
  background: #fff;
}

/* ── 分割线 ──────────────────────────── */

.divider {
  display: flex;
  align-items: center;
  margin: 36rpx 0;
}

.divider-line {
  flex: 1;
  height: 2rpx;
  background: #eee;
}

.divider-text {
  margin: 0 24rpx;
  font-size: 26rpx;
  color: #bbb;
}
