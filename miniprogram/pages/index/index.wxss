/* 首页 — 居中卡片布局，移动端竖屏适配 */

.page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #2d5016 0%, #3a6b1e 40%, #f5f5f5 40%);
}

.card {
  width: 100%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
}

/* ── 标题区 ──────────────────────────── */

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.logo {
  font-size: 96rpx;
  line-height: 1.2;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #2d5016;
  margin-top: 8rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

/* ── 输入区 ──────────────────────────── */

.field {
  margin-bottom: 32rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  background: #fafafa;
}

.input:focus {
  border-color: #2d5016;
  background: #fff;
}

/* ── 按钮 ────────────────────────────── */

.btn-primary {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #2d5016;
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  text-align: center;
}

.btn-primary[disabled] {
  opacity: 0.6;
}

/* ── 错误提示 ────────────────────────── */

.error-msg {
  background: #fff0f0;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 24rpx;
}

.error-msg text {
  font-size: 26rpx;
  color: #d32f2f;
}

/* ── 底部 ────────────────────────────── */

.footer {
  margin-top: 40rpx;
  display: flex;
  align-items: center;
}

.footer text {
  font-size: 24rpx;
  color: #bbb;
}

.footer-dot {
  margin: 0 12rpx;
}
