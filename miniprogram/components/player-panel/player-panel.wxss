/* player-panel 玩家面板样式 */

.player-panel {
  background: rgba(255, 255, 255, 0.12);
  border: 2rpx solid rgba(255, 255, 255, 0.25);
  border-radius: 12rpx;
  padding: 14rpx 16rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  transition: border-color 0.2s;
}

.player-panel.me {
  border-color: #ffd54f;
  background: rgba(255, 213, 79, 0.18);
}

.player-panel.turn {
  border-color: #ff5252;
  box-shadow: 0 0 12rpx rgba(255, 82, 82, 0.4);
}

.player-panel.offline {
  opacity: 0.5;
}

/* header */
.panel-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.seat-badge {
  background: rgba(255, 255, 255, 0.3);
  border-radius: 6rpx;
  padding: 2rpx 12rpx;
  display: inline-flex;
}

.seat-badge text {
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
}

.dealer-tag {
  font-size: 20rpx;
  background: #d32f2f;
  color: #fff;
  border-radius: 4rpx;
  padding: 0 8rpx;
  font-weight: 600;
}

.offline-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #bdbdbd;
  margin-left: auto;
}

/* body */
.nickname {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.score {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* footer */
.panel-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 2rpx;
}

.hand-count {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}

.turn-indicator {
  font-size: 22rpx;
  color: #ff5252;
  font-weight: 600;
  background: rgba(255, 255, 255, 0.85);
  border-radius: 6rpx;
  padding: 2rpx 12rpx;
}
