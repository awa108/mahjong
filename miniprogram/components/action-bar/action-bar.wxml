<!-- action-bar 操作栏 — 按钮由 allowedActions 决定 -->
<view class="action-bar">
  <button
    wx:for="{{ visibleButtons }}"
    wx:key="action"
    class="btn-action {{ item.class }}"
    data-action="{{ item.action }}"
    bindtap="onTap"
    disabled="{{ loading }}"
  >{{ item.label }}</button>
  <text wx:if="{{ !visibleButtons.length }}" class="no-actions">等待对局…</text>
</view>
