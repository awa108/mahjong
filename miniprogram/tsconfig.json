{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "lib": ["ES2020"],
    "types": [],
    "paths": {
      "@mahjong/shared": ["../shared/src/index.ts"],
      "@mahjong/shared/*": ["../shared/src/*"]
    },
    "baseUrl": ".",
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
  "include": ["**/*.ts"]
}
